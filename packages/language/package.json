{
  "name": "@agentscript/language",
  "version": "2.5.4",
  "description": "Language infrastructure, analysis engine, and Language Service API for AgentScript dialects",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./lint": {
      "import": "./dist/lint/index.js",
      "types": "./dist/lint/index.d.ts"
    },
    "./service": {
      "import": "./dist/service.js",
      "types": "./dist/service.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --passWithNoTests --coverage --coverage.reporter=lcov --coverage.reporter=json-summary --coverage.reportsDirectory=coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentscript/types": "workspace:*"
  },
  "devDependencies": {
    "@agentscript/parser": "workspace:*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
  },
  "keywords": [
    "agentscript",
    "language",
    "analysis",
    "lint",
    "ast"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
