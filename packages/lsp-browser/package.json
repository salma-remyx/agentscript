{
  "name": "@agentscript/lsp-browser",
  "version": "2.2.60",
  "description": "Browser LSP server for AgentScript — runs in a web worker with WASM parser",
  "type": "module",
  "main": "dist/index.bundle.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.bundle.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "node build.mjs",
    "build:tree-sitter": "node build.mjs --tree-sitter",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentscript/agentforce": "2.5.60",
    "@agentscript/lsp": "2.3.9",
    "@agentscript/types": "0.2.3",
    "vscode-languageserver": "^9.0.1"
  },
  "devDependencies": {
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.27.4"
  },
  "keywords": [
    "agentscript",
    "lsp",
    "language-server",
    "browser",
    "typescript"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}
