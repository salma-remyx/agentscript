{
  "name": "@agentscript/agentforce",
  "version": "2.5.34",
  "description": "Batteries-included AgentScript SDK for Agentforce — parse, mutate, emit, lint",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser.js",
      "types": "./dist/index.d.ts"
    },
    "./browser.iife.js": "./dist/browser.iife.js",
    "./wasm": {
      "import": "./dist/wasm-constants.js",
      "types": "./dist/wasm-constants.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "node build.mjs",
    "build:tree-sitter": "node build.mjs --tree-sitter",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=lcov --coverage.reporter=json-summary --coverage.reportsDirectory=coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentscript/agentforce-dialect": "workspace:*",
    "@agentscript/compiler": "workspace:*",
    "@agentscript/language": "workspace:*",
    "@agentscript/parser": "workspace:*",
    "@agentscript/types": "workspace:*"
  },
  "peerDependencies": {
    "web-tree-sitter": ">=0.22.0"
  },
  "peerDependenciesMeta": {
    "web-tree-sitter": {
      "optional": true
    }
  },
  "devDependencies": {
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.28.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6",
    "web-tree-sitter": "^0.25.10"
  },
  "keywords": [
    "agentscript",
    "agentforce",
    "salesforce",
    "parser",
    "sdk"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
