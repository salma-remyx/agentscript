{
  "name": "@agentscript/lsp",
  "version": "2.3.8",
  "description": "Language Server Protocol implementation for AgentScript — dialect-agnostic core",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=lcov --coverage.reporter=json-summary --coverage.reportsDirectory=coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentscript/agentforce-dialect": "2.13.4",
    "@agentscript/agentscript-dialect": "2.11.1",
    "@agentscript/language": "2.8.4",
    "@agentscript/parser": "4.0.2",
    "@agentscript/types": "0.2.3",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
  },
  "keywords": [
    "agentscript",
    "lsp",
    "language-server"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
