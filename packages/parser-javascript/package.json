{
  "name": "@agentscript/parser-javascript",
  "version": "2.4.1",
  "license": "Apache-2.0",
  "description": "Hand-written TypeScript parser for AgentScript language",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:update": "vitest run -u",
    "bench": "vitest bench",
    "perf": "tsx test/run-perf.ts",
    "perf:report": "tsx test/run-perf.ts --report"
  },
  "dependencies": {
    "@agentscript/types": "workspace:*",
    "tiny-invariant": "^1.3.3"
  },
  "devDependencies": {
    "@agentscript/parser-tree-sitter": "workspace:*",
    "csv-parse": "^6.2.1",
    "tree-sitter": "^0.25.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
