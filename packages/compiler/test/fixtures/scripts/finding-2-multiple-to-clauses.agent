config:
    agent_name: "Finding2"

start_agent main:
    description: "Multiple `to` clauses on one transition — only one target is meaningful"
    before_reasoning:
        transition to @subagent.a, to @subagent.b
    reasoning:
        instructions: ->
            | hello

subagent a:
    description: "a"
    reasoning:
        instructions: ->
            | I am A

subagent b:
    description: "b"
    reasoning:
        instructions: ->
            | I am B
