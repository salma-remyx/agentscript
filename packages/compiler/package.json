{
  "name": "@agentscript/compiler",
  "version": "2.7.1",
  "description": "Compiler for AgentScript — transforms parsed AST into AgentJSON (AgentDSLAuthoring)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./generated/agent-dsl": {
      "import": "./dist/generated/agent-dsl.js",
      "types": "./dist/generated/agent-dsl.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=lcov --coverage.reporter=json-summary --coverage.reportsDirectory=coverage",
    "test:watch": "vitest",
    "test:compare": "tsx scripts/generate-comparison-report.ts",
    "generate:outputs": "tsx scripts/generate-outputs.ts",
    "compare:agentdsl": "pnpm generate:outputs && tsx test/compare-outputs.ts",
    "fixtures:regen": "tsx scripts/regen-fixtures.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentscript/agentforce-dialect": "workspace:*",
    "@agentscript/language": "workspace:*",
    "@agentscript/parser": "workspace:*",
    "@agentscript/types": "workspace:*",
    "@jridgewell/gen-mapping": "^0.3.5",
    "@jridgewell/trace-mapping": "^0.3.25",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@agentscript/agentscript-dialect": "workspace:*",
    "@agentscript/parser": "workspace:*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6",
    "yaml": "^2.8.3"
  },
  "keywords": [
    "agentscript",
    "compiler",
    "agentjson"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
