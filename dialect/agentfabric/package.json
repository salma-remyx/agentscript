{
  "name": "@agentscript/agentfabric-dialect",
  "version": "0.1.30",
  "description": "AgentFabric dialect — schema, lint rules, compiler, and dialect config",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "prebuild": "node ../../scripts/sync-pkg-meta.mjs",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --coverage --coverage.reporter=lcov --coverage.reporter=json-summary --coverage.reportsDirectory=coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentscript/agentscript-dialect": "workspace:*",
    "@agentscript/language": "workspace:*"
  },
  "devDependencies": {
    "@agentscript/parser": "workspace:*",
    "tree-sitter": "^0.25.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
  },
  "keywords": [
    "agentscript",
    "agentfabric",
    "dialect",
    "schema",
    "lint",
    "compiler"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}
