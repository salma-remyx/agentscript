{
  "name": "agentscript-monorepo",
  "version": "2.0.0",
  "private": true,
  "description": "AgentScript language and toolchain monorepo",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test && yarn test:scs",
    "test:scs": "vitest run scripts/scs",
    "scs:upload": "tsx scripts/scs/upload.ts",
    "scs:smoke": "tsx scripts/scs/smoke.ts",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "validate-plugins": "tsx ci/validate-plugins.ts",
    "extract-diagnostics": "tsx scripts/extract-diagnostics.ts",
    "dev": "turbo run dev --parallel",
    "docs:dev": "yarn workspace @agentscript/docs dev",
    "docs:build": "yarn workspace @agentscript/docs build",
    "docs:serve": "yarn workspace @agentscript/docs serve",
    "docs:typedoc": "typedoc",
    "ui:dev": "yarn workspace @agentscript/ui dev",
    "release:dry": "multi-semantic-release --dry-run",
    "prepare": "husky"
  },
  "workspaces": [
    "packages/*",
    "dialect/*",
    "apps/*"
  ],
  "resolutions": {
    "vite": "^7.3.2"
  },
  "dependenciesMeta": {
    "tree-sitter@0.25.0": {
      "built": false
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "header-max-length": [
        2,
        "always",
        140
      ],
      "subject-case": [
        0
      ]
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@grpc/grpc-js": "^1.14.4",
    "@qiwi/multi-semantic-release": "^7.1.2",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^20.19.41",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lerna": "^8.2.0",
    "lint-staged": "^15.5.2",
    "playwright": "^1.49.0",
    "prettier": "^3.8.3",
    "protobufjs": "^8.5.0",
    "semantic-release": "^21.1.2",
    "tsx": "^4.21.0",
    "turbo": "^2.9.12",
    "typedoc": "0.26.11",
    "typedoc-plugin-markdown": "4.2.10",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^3.2.4",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=4.0.0"
  },
  "packageManager": "yarn@4.0.2",
  "volta": {
    "node": "22.22.1"
  }
}
