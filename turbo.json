{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": ["NEXUS_B64_RO_TOKEN"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["VITE_BASE_PATH", "DOCS_BASE_PATH"],
      "outputs": ["dist/**", ".next/**", "build/**", ".docusaurus/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "format": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
